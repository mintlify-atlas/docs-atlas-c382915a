  "keyFeatures": [
    "Persistent multi-turn ACP sessions",
    "Named sessions for parallel workstreams",
    "Prompt queueing with cooperative cancellation",
    "Multiple built-in agent support (pi, openclaw, codex, claude)",
    "Structured JSON output for automation",
    "Permission management and sandboxing",
    "Fire-and-forget mode with --no-wait",
    "Session crash recovery and reconnect"
  ],
  "publicApiSurface": [
    "acpx <agent> prompt",
    "acpx <agent> exec",
    "acpx <agent> sessions new",
    "acpx <agent> sessions list",
    "acpx <agent> sessions show",
    "acpx <agent> sessions history",
    "acpx <agent> sessions close",
    "acpx <agent> cancel",
    "acpx <agent> set-mode",
    "acpx <agent> set",
    "acpx <agent> status",
    "acpx config show",
